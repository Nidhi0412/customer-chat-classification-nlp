# Database Configuration (Optional - only if using database query agent)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database_name

# OpenAI API Configuration (Optional - only if using database query agent)
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
SENTENCE_BERT_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# Processing Configuration
BATCH_SIZE=128
NUM_CLUSTERS=30
TOP_N_SIMILAR=1000
FUZZY_THRESHOLD=85

# File Paths (Update these to match your directory structure)
ROOT_DIRECTORY=/path/to/your/json/files
OUTPUT_DIRECTORY=/path/to/output/directory
EMBEDDINGS_PATH=/path/to/embeddings
FAISS_INDEX_PATH=/path/to/faiss/index

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=chat_classification.log

# Optional: Encryption
DATA_ENCRYPTION_KEY=your_encryption_key_here

# Optional: Performance
USE_GPU=false
MAX_WORKERS=4
